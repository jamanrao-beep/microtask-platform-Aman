# Rename this file to .env (Prisma reads .env, not .env.local)

# SQLite — no setup needed, file is created automatically
DATABASE_URL="file:./prisma/dev.db"

# NextAuth secret — for production, generate with: openssl rand -base64 32
NEXTAUTH_SECRET="microtask-platform-demo-secret-2024"
NEXTAUTH_URL="http://localhost:3000"
